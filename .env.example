# ============ 数据库 ============
# MySQL 8.4 连接串：mysql://用户名:密码@主机:端口/数据库名
# 端口 3306 对应 docker-compose.yml 的端口映射（与 Django 项目的 mysql 容器端口 3307 独立）
DATABASE_URL="mysql://root:root123@localhost:3306/ecommerce"

# ============ JWT 鉴权 ============
# 生产环境务必换成强随机串（至少 32 字节），可用 openssl rand -base64 32 生成
JWT_SECRET="dev-secret-please-change-in-production-32bytes"
# Access Token 过期时间
JWT_EXPIRES_IN="7d"

# ============ 服务 ============
PORT=3000
NODE_ENV="development"

# ============ CORS ============
# 前端地址，多个用逗号分隔；开发环境可用 *
CORS_ORIGIN="http://localhost:5173"

# ============ Redis ============
# 缓存 / 登录限流 / JWT 黑名单
# 端口 6380 对应 docker-compose.yml 映射，避开 Django 项目的 redis(6379)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
